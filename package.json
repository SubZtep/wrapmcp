{
  "name": "wrapmcp",
  "version": "0.0.1",
  "description": "Wrap any CLI tool with MCP - Universal MCP server for well-documented CLI apps",
  "private": false,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "build": "bun build src/index.ts --outfile wrapmcp --compile"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
